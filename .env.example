# fhir-codebridge Environment Configuration
# Copy this file to .env and edit values before deployment.
# For production, use Docker secrets instead of plaintext env vars.
# See INSTALL.md for details.

# --- Required for full terminology coverage ---
# UMLS API key from NLM (free, 1-2 business day approval)
# Register at: https://uts.nlm.nih.gov/uts/signup
# Without this, service runs with 123K+ verified terms (CMS ICD-10-CM + NLM RxNorm + CDT + LOINC core)
# With UMLS loaded: 600K+ terms (SNOMED-CT, ICD-10-CM, LOINC, RxNorm)
# To load full terminology: place MRCONSO.RRF in data/terminology_raw/umls/
# See data/terminology_parsed/README.md for instructions
UMLS_API_KEY=
# LISA_UMLS_API_KEY_FILE=/run/secrets/umls_api_key

# --- Required for API authentication ---
# Comma-separated list of API keys with roles
# Format: key1:role1,key2:role2
# Roles: admin (full access + audit log), read (lookup + translate only)
# GENERATE A STRONG KEY: openssl rand -hex 32
LISA_API_KEYS=changeme-admin-key:admin,changeme-readonly-key:read

# --- Auth Mode ---
# By default, auth is ENABLED. Set LISA_API_KEYS above.
# To explicitly disable auth (dev/local only!):
# LISA_AUTH_DISABLED=1

# --- CORS (optional) ---
# Comma-separated list of allowed origins. If not set, same-origin only (most secure).
# LISA_CORS_ORIGINS=https://your-frontend.example.com

# --- Optional ---
# Port for the API server (default: 8000)
LISA_PORT=8000

# Path to audit log file (default: data/audit.logl)
LISA_AUDIT_LOG=data/audit.log

# --- Docker Secrets (overrides env vars above) ---
# If using Docker secrets, set these to the file paths instead:
# LISA_UMLS_API_KEY_FILE=/run/secrets/umls_api_key
# LISA_API_KEYS_FILE=/run/secrets/lisa_api_keys